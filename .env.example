# 저녁 넛지 리마인더 — 환경 설정 예시
# 이 파일을 `.env`로 복사한 뒤 실제 값을 채운다: cp .env.example .env
# 실제 `.env`는 커밋하지 않는다(.gitignore 등록됨).

# Turso 원격 DB. 둘 다 설정하면 아래 DATABASE_URL보다 우선한다.
TURSO_CONN=libsql://your-database.turso.io
TURSO_TOKEN=change-me

# 로컬 SQLite 파일 경로. Turso를 쓰면 생략 가능하다.
# 기본값이면 생략 가능. 상대 경로는 실행 CWD(저장소 루트) 기준.
DATABASE_URL=sqlite:///./data/nudge.db

# ntfy 발행 대상 (F-04)
NTFY_BASE_URL=https://ntfy.example.com
NTFY_TOPIC=nudge-after-work
NTFY_ACCESS_TOKEN=change-me

# ntfy 액션 버튼이 클릭 시 호출할, 외부에서 접근 가능한 이 앱의 URL (F-05).
# HTTPS 종단(TLS)은 앱이 아니라 앞단(Cloudflare Tunnel, Caddy 등)에서 처리한다는 전제.
WEBHOOK_BASE_URL=https://nudge.example.com
# 버튼 URL의 ?token= 검증용 임의 문자열. 예: `openssl rand -hex 16`로 생성.
WEBHOOK_TOKEN=change-me-to-a-long-random-string

# 관리 화면 HTTP Basic 인증 비밀번호 (F-08).
# 로컬 네트워크 전제의 최소 인증이다. Basic 자격증명은 base64 인코딩일 뿐 암호화가
# 아니므로, 관리 화면을 인터넷에 공개한다면 HTTPS(TLS)를 앱이 아니라 앞단(Cloudflare
# Tunnel, Caddy 등)에서 반드시 종단해 자격증명이 평문으로 노출되지 않게 해야 한다.
ADMIN_PASSWORD=change-me

# 시각 판단 기준 시간대 (기본 Asia/Seoul)
TIMEZONE=Asia/Seoul

# 최초 알림 유예 창(분). start_time 이후 이 시간 안에만 최초 발송한다 (F-06).
TRIGGER_GRACE_MINUTES=10
